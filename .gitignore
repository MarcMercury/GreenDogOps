# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but DO track the documented template (no secrets).
!.env.example

# local secrets (Supabase access token etc.) — NEVER commit
/.secrets/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local source data (PII — never commit)
/.data/

# ezyVet source exports dropped into public/ (PII — never commit or deploy;
# served publicly by Next.js from public/. Data is loaded into the DB instead).
/public/*.csv
# Marketing/HR source workbooks & docs dropped into public/ (PII + plaintext
# credentials — never commit or deploy; served publicly by Next.js. Data is
# loaded into the DB / credentials vault instead).
/public/*.xlsx
/public/*.xls
/public/*.pdf
/public/*.docx

# Python cache
__pycache__/
*.pyc
