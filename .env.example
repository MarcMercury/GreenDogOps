# Green Dog Ops — environment variables
# Copy to .env.local and fill in. NEVER commit .env.local.
#
# IMPORTANT: This app SHARES a Supabase project with EmployeeGMGDD but is fully
# isolated in its own Postgres schema (see NEXT_PUBLIC_SUPABASE_DB_SCHEMA below).
#
# Convention: NEXT_PUBLIC_* are exposed to the browser. Everything else is
# server-only (Server Components, Server Actions, Route Handlers, cron).
# Production values live in the Vercel project (green-dog-ops).

# --- Supabase (shared project, isolated schema) ---
NEXT_PUBLIC_SUPABASE_URL=https://uekumyupkhnpjpdcjfxb.supabase.co
# Publishable / anon key (safe for the browser).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Dedicated schema that isolates Green Dog Ops data from EmployeeGMGDD (public).
NEXT_PUBLIC_SUPABASE_DB_SCHEMA=greendogops

# --- Server-only secrets (NEVER expose to the browser, no NEXT_PUBLIC_ prefix) ---
# Service-role key BYPASSES RLS. Used by createAdminClient() for bulk imports,
# cron jobs, and AI auto-update routines. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# --- Cron / scheduled jobs ---
# Shared secret to authenticate Vercel Cron requests to protected routes.
CRON_SECRET=

# --- AI / LLM providers ---
# Two features use AI, and BOTH try providers in order and fall through on
# failure so a single provider's quota/rate limit never breaks the feature:
#   1. ATS resume/list parsing (src/lib/ats/import.ts) — callLLM() chain.
#      Order via LLM_PROVIDER_ORDER (default: gemini,groq,openrouter,openai,anthropic).
#   2. Resources web search (src/app/(app)/resources/actions.ts) — searchWeb() chain.
#      Order via WEB_SEARCH_PROVIDER_ORDER (default: google,tavily,openai,claude).
# Defaults lead with free / quota-independent providers so paid OpenAI / Claude
# tokens are only spent as a last resort. Set any subset of keys below — more
# keys = more resilience. Unconfigured providers are skipped silently.
LLM_PROVIDER_ORDER=
WEB_SEARCH_PROVIDER_ORDER=

OPENAI_API_KEY=
OPENAI_PROJECT_ID=
OPENAI_MODEL=
OPENAI_BASE_URL=
OPENAI_SCHEDULE_MODEL=
# Model used by the Resources web search (default gpt-4o-mini-search-preview).
OPENAI_SEARCH_MODEL=
# Anthropic Claude — fallback for both AI features.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
ANTHROPIC_BASE_URL=
# Google Gemini — free tier; used by both AI features (resume parsing + search).
# GOOGLE_API_KEY is used if set, otherwise GEMINI_API_KEY.
GEMINI_API_KEY=
GEMINI_MODEL=
GOOGLE_API_KEY=
GEMINI_BASE_URL=
# Fast/cheap inference fallback (marked sensitive in Vercel — set manually).
GROQ_API_KEY=
GROQ_MODEL=
# OpenRouter — routes to many models incl. free ones; ATS resume-parse fallback.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
# Optional site attribution sent to OpenRouter (defaults to app URL).
OPENROUTER_SITE_URL=

# --- Image / 3D generation ---
STABILITY_API_KEY=
MESHY_API_KEY=

# --- Vector store (Policies semantic search / RAG) ---
# NOTE: PINECONE_API_KEY is required for Pinecone and is NOT yet set anywhere.
# Alternative: use Supabase pgvector and skip Pinecone entirely.
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_ENVIRONMENT=

# --- Google: Maps, Custom Search, Service Account (Calendar, etc.) ---
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_PUBLIC_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=
# Full service-account JSON (single-line). Used for Google Calendar sync, etc.
GOOGLE_SERVICE_ACCOUNT_JSON=

# --- Web search / contact enrichment (ATS prospects, CRM data) ---
BRAVE_API_KEY=
TAVILY_API_KEY=
SERPAPI_API_KEY=
APOLLO_API_KEY=
# Email finder/verifier (marked sensitive in Vercel — set manually).
HUNTER_API_KEY=

# --- Geocoding ---
NOMINATIM_USER_AGENT=

# --- Email (transactional) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Notifications ---
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=
# Cron/uptime monitoring.
CRONITOR_API_KEY=

# --- Scheduling / time tracking ---
CALCOM_API_KEY=
CALCOM_BASE_URL=
CLOCKIFY_API_KEY=

# --- Veterinary PIMS integration (ezyVet) ---
EZYVET_WEBHOOK_SECRET=

# --- Break-glass / emergency admin access ---
EMERGENCY_ADMIN_EMAIL=
EMERGENCY_ADMIN_NAME=
EMERGENCY_ADMIN_SECRET=
